# Local SQLite database used for laptop development.
DATABASE_URL="file:./dev.db"

# Comma-separated founder/admin emails that can open /admin.
# Keep this list small in private beta.
STUDIOFLOW_ADMIN_EMAILS="daniel@studioflow.test"

# Public URL of the deployed app. Optional in the MVP, useful once deployed.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

